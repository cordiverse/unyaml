{
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "src",
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "types": [
      "node",
    ],
  },
  "include": [
    "src",
  ],
}

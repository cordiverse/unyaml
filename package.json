{
  "name": "@cordisjs/unyaml",
  "description": "Universal YAML loader for Node.js, esbuild and Vite",
  "version": "2.0.0",
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "main": "lib/index.mjs",
  "files": [
    "lib",
    "types.d.ts"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./esbuild": {
      "types": "./lib/esbuild.d.ts",
      "default": "./lib/esbuild.cjs"
    },
    "./vite": {
      "types": "./lib/vite.d.ts",
      "default": "./lib/vite.cjs"
    },
    "./types": "./types.d.ts",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cordiverse/unyaml.git"
  },
  "bugs": {
    "url": "https://github.com/cordiverse/unyaml/issues"
  },
  "homepage": "https://github.com/cordiverse/unyaml",
  "author": "Shigma <shigma10826@gmail.com>",
  "license": "MIT",
  "keywords": [
    "yaml",
    "yml",
    "register",
    "require",
    "import",
    "loader",
    "hook",
    "pirates",
    "esbuild",
    "vite",
    "plugin"
  ],
  "scripts": {
    "build": "tsc -b && dumble"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "tosource": "^2.0.0-alpha.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "dumble": "^0.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
